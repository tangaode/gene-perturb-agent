# LLM backend options: deepseek | openai | qwen
LLM_BACKEND=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# Required for deepseek/openai/qwen
LLM_API_KEY=

VIRTUALCELL_URL=http://virtualcell_service:8001
EVIDENCE_URL=http://evidence_service:8002
NCBI_API_KEY=
UP_P_THRESHOLD=0.6
DOWN_P_THRESHOLD=0.6
TOPN_CANDIDATES=50
VERIFY_TOPK=5
FINAL_TOPK=5
EVIDENCE_TIMEOUT=600

# Host paths for docker volumes
MTX_DIR_HOST=G:/xunixibao/data/GSM7831813
VCACHE_DIR_HOST=G:/xunixibao/code/gene-perturb-agent/cache
